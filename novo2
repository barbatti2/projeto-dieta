<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Projeto Dieta Premium</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        .nav-btn { transition: all 0.2s; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
    </style>
</head>
<body class="bg-slate-50 flex h-screen overflow-hidden">

    <aside class="w-64 bg-slate-100 border-r border-slate-200 flex flex-col p-4">
        <div class="flex flex-col items-center text-center py-4 border-b border-slate-200 mb-6 gap-2">
            <div class="p-2.5 bg-blue-600 text-white rounded-xl shadow-md">
                <i data-lucide="heart-pulse"></i>
            </div>
            <h2 class="font-extrabold text-slate-900 uppercase tracking-tight">Projeto Dieta</h2>
        </div>

        <nav class="space-y-1">
            <button onclick="switchTab('inicio')" id="nav-inicio" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold text-slate-600 hover:bg-slate-200"><i data-lucide="home" class="w-4 h-4"></i> Início</button>
            <button onclick="switchTab('adicionar')" id="nav-adicionar" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold text-slate-600 hover:bg-slate-200"><i data-lucide="plus-circle" class="w-4 h-4"></i> Adicionar Alimento</button>
            <button onclick="switchTab('historico')" id="nav-historico" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold text-slate-600 hover:bg-slate-200"><i data-lucide="list" class="w-4 h-4"></i> Histórico</button>
            <button onclick="switchTab('config')" id="nav-config" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-semibold text-slate-600 hover:bg-slate-200"><i data-lucide="settings" class="w-4 h-4"></i> Configurações</button>
        </nav>
    </aside>

    <main class="flex-1 p-8 overflow-y-auto">
        <div id="tab-inicio" class="tab-content active"><h2 class="text-3xl font-bold">Início</h2></div>
        
        <div id="tab-adicionar" class="tab-content">
            <h2 class="text-3xl font-bold mb-6">Adicionar Refeição</h2>
            <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 max-w-md">
                <input type="text" id="input-alimento" placeholder="Nome do Alimento" class="w-full p-3 mb-4 border rounded-lg">
                <input type="number" id="input-calorias" placeholder="Calorias" class="w-full p-3 mb-4 border rounded-lg">
                <button onclick="capturarDadosRefeicao()" class="w-full bg-blue-600 text-white py-3 rounded-lg font-bold">Salvar Refeição</button>
            </div>
        </div>

        <div id="tab-historico" class="tab-content"></div>
    </main>

    <script>
        let db = { historico: [] };
        let selectedMealMoment = 'Café da Manhã';

        function switchTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.nav-btn').forEach(btn => {
                btn.classList.remove('bg-blue-600', 'text-white', 'shadow-md');
                btn.classList.add('text-slate-600', 'hover:bg-slate-200');
            });

            document.getElementById(`tab-${tabId}`).classList.add('active');
            const btn = document.getElementById(`nav-${tabId}`);
            if(btn) { btn.classList.add('bg-blue-600', 'text-white', 'shadow-md'); btn.classList.remove('text-slate-600'); }

            if(tabId === 'historico') renderFullHistory();
            if(typeof lucide !== 'undefined') lucide.createIcons();
        }

        function capturarDadosRefeicao() {
            const alimento = document.getElementById('input-alimento').value;
            const cal = document.getElementById('input-calorias').value;
            if(!alimento || !cal) return alert("Preencha tudo!");
            
            db.historico.push({ id: Date.now(), nome: alimento, cal: cal, data: new Date().toLocaleDateString() });
            alert("Salvo!");
            document.getElementById('input-alimento').value = '';
            document.getElementById('input-calorias').value = '';
            switchTab('historico');
        }

        function renderFullHistory() {
            const container = document.getElementById('tab-historico');
            let html = `<h2 class="text-3xl font-bold mb-6">Histórico</h2>`;
            db.historico.forEach(r => {
                html += `<div class="p-4 mb-2 bg-white rounded-lg shadow flex justify-between">
                            <span>${r.nome} - ${r.cal} kcal</span>
                            <button onclick="excluir(${r.id})" class="text-red-500">Excluir</button>
                         </div>`;
            });
            container.innerHTML = html;
        }

        function excluir(id) {
            db.historico = db.historico.filter(r => r.id !== id);
            renderFullHistory();
        }

        document.addEventListener('DOMContentLoaded', () => { switchTab('inicio'); lucide.createIcons(); });
    </script>
</body>
</html>
